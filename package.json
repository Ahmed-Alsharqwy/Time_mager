{
  "name": "nexus-discipline-os",
  "version": "2.0.0",
  "description": "NEXUS — Personal Productivity & Discipline OS",
  "private": true,
  "scripts": {
    "cap:init":    "npx cap init NEXUS com.nexus.disciplineos --web-dir .",
    "cap:add":     "npx cap add android",
    "cap:sync":    "npx cap sync android",
    "cap:open":    "npx cap open android",
    "cap:run":     "npx cap run android",
    "cap:build":   "npx cap build android",
    "android:dev": "npm run cap:sync && npm run cap:open"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/splash-screen": "^5.0.7",
    "@capacitor/status-bar": "^5.0.7",
    "@capacitor/keyboard": "^5.0.8",
    "@capacitor/local-notifications": "^5.0.7",
    "@capacitor/push-notifications": "^5.1.3",
    "@capacitor/haptics": "^5.0.7",
    "@capacitor/app": "^5.0.7",
    "@capacitor/browser": "^5.0.6"
  }
}
